generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// datasource db {
//   provider = "sqlite"
// }

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  telephone     String?
  image         String
  emailVerified Boolean  @default(false)
  roleId        Int      @default(2) @map("role_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  role Role @relation(fields: [roleId], references: [id])

  movements     Movement[]
  accounts      Account[]
  sessions      Session[]
  verifications Verification[]

  @@index([roleId])
  @@map("users")
}

model Account {
  id                    String    @id @default(cuid())
  user                  User      @relation(fields: [userId], references: [id])
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Session {
  id        String   @id
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  token     String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime
}

model Movement {
  id    String   @id @default(cuid())
  monto Decimal
  fecha DateTime

  typeId Int    @map("type_id")
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  type typeMovement @relation(fields: [typeId], references: [id])
  user User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([typeId])
  @@index([fecha])
  @@map("Movements")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  createdAt DateTime @default(now()) @map("created_at")

  users User[]

  @@map("roles")
}

model typeMovement {
  id   Int    @id @default(autoincrement())
  name String @unique

  createdAt DateTime @default(now()) @map("created_at")

  movements Movement[]

  @@map("types_Movement")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
}
